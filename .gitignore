# Comparison scratch artifacts
data/outputs/comparison*/run_*.log
data/outputs/comparison*/run_*_stderr.log
data/outputs/comparison*/model_comparison.live.csv
data/outputs/comparison*/*_legacy.csv
data/outputs/comparison*/*_offplan.csv
data/outputs/comparison*/*.tmp

# Local-only workspace artifacts
.bundle_staging_*/
Models/
gcm-diagnose.log

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Hugging Face model cache ----
