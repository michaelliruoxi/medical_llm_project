# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# ---- Environment ----
.env
.venv/
venv/
env/

# ---- Data (large / generated) ----
# Raw MedQuAD XML corpus (~10k files) — users clone it themselves
data/raw/MedQuAD/

# Processed outputs generated by the pipeline
data/processed/*.csv
data/processed/*.parquet

# LLM response cache (hash-named JSON files, can be large)
data/outputs/cache/

# Generated reports and result artifacts (reproducible from code)
data/outputs/report_data.json
data/outputs/local_test_report.md
data/outputs/*.csv
data/outputs/*.tex
data/outputs/*.png

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- HuggingFace model cache ----
# Models are downloaded on first run; no need to commit them
*.safetensors
*.bin
*.h5

# ---- IDE / OS ----
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store
desktop.ini

# ---- Keep .gitkeep files (override above ignores) ----
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/outputs/.gitkeep
!notebooks/.gitkeep
